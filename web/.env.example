# Copy to .env.local and adjust if your backend is at a different URL.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# --- Admin logs gate (server-only — do NOT prefix with NEXT_PUBLIC) ---
# Password viewers type at /login to unlock the query logs at /admin/*.
ADMIN_LOGS_PASSWORD=
# HMAC signing key for the session cookie. Generate a 256-bit random value:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_SESSION_SECRET=
